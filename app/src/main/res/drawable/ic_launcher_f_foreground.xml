<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Use the PNG as the foreground.
         Adaptive icon foregrounds are 108x108dp.
         The safe zone is the center 66dp.
         If we want the logo to be large, we can scale it.
    -->
    <item
        android:drawable="@drawable/ic_launcher_f"
        android:gravity="center"
        android:width="108dp"
        android:height="108dp" />
</layer-list>